# ============================================================
# FinObras — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/finobras

# JWT
JWT_SECRET=cambiar_por_string_aleatorio_largo_minimo_32_caracteres
JWT_EXPIRY=8h

# Email (Gmail — usar App Password, no la contraseña normal)
EMAIL_USER=tu-cuenta@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://tu-app.railway.app
